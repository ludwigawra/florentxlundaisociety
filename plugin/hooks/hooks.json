{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "_comment": "AI-OS plugin hook declarations. Auto-discovered by Claude Code when the plugin is installed via /plugin install. Paths resolve via ${CLAUDE_PLUGIN_ROOT} so hooks fire from inside the installed plugin directory — the user's brain folder is never touched. The legacy install.sh shell flow uses plugin/settings.template.json instead, which copies hooks into the brain and resolves via $CLAUDE_PROJECT_DIR.",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/session-start.sh\"",
            "timeout": 5000
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/session-end.sh\"",
            "timeout": 10000
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/post-tool-failure.sh\"",
            "timeout": 3000
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/user-prompt-submit.sh\"",
            "timeout": 2000
          }
        ]
      }
    ]
  }
}
